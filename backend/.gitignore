# 4. Create .gitignore file
@"
# Environment files
*.env
.env
.env.*
*.env.*
backend/.env
backend/.env.*
.env.local
.env.development

# Dependencies
node_modules/
package-lock.json
yarn.lock

# Build outputs
dist/
build/
out/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
coverage/
.nyc_output/

# Misc
.env.backup
*.bak
"@ | Out-File -FilePath .gitignore -Encoding UTF8